# === OSINT War Room Configuration ===

# Telegram Bot (required for notifications)
# 1. Message @BotFather on Telegram, type /newbot
# 2. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here
# 3. Message @userinfobot on Telegram to get your chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# ACLED (free registration at acleddata.com)
# Use the same email + password you used to register on acleddata.com
# ACLED uses OAuth now — no separate API key needed
ACLED_EMAIL=your_acled_email@example.com
ACLED_PASSWORD=your_acled_password_here

# NASA FIRMS (free registration at earthdata.nasa.gov)
FIRMS_MAP_KEY=your_firms_map_key_here

# Optional: Proxy (route all traffic through VPN/proxy)
# HTTP_PROXY=socks5://127.0.0.1:1080
# HTTPS_PROXY=socks5://127.0.0.1:1080

# Alert thresholds
GOLDSTEIN_CRITICAL=-8
GOLDSTEIN_HIGH=-5
GOLDSTEIN_MEDIUM=-3

# Data retention (days)
RETENTION_DAYS=90
